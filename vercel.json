{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/src/index.html"
    },
    {
      "source": "/auth/error",
      "destination": "/src/auth-error.html"
    },
    {
      "source": "/germinal",
      "destination": "https://REPLACE_WITH_RAILWAY_FRONTEND_DOMAIN/germinal"
    },
    {
      "source": "/germinal/:path*",
      "destination": "https://REPLACE_WITH_RAILWAY_FRONTEND_DOMAIN/germinal/:path*"
    },
    {
      "source": "/((?!src/).*)",
      "destination": "/src/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
